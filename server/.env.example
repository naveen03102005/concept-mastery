# ============================================================
# School Portal – Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Supabase (required) ──────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
# Anon key (optional – only needed if you use the anon client anywhere)
# SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Server ───────────────────────────────────────────────────
PORT=3001

# ── Frontend URL (for CORS) ──────────────────────────────────
# Set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173

# ── AI / Grok API ────────────────────────────────────────────
# Get from: https://console.x.ai/
GROK_API_KEY=YOUR_GROK_API_KEY_HERE
# XAI_API_KEY=YOUR_XAI_API_KEY_HERE   (alias – either one works)
